{
  "name": "myt-root",
  "description": "",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.16.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "npx tsc --incremental --noEmit",
    "clean": "rimraf --glob packages/*/dist temp",
    "lint": "oxlint",
    "format": "oxfmt",
    "format-check": "oxfmt --check",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm check",
    "commit-msg": "node scripts/verify-commit.mjs"
  },
  "lint-staged": {
    "*.{js,mjs,json}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.ts?(x)": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/browser-playwright": "catalog:",
    "chalk": "^5.6.2",
    "lint-staged": "^17.0.5",
    "npm-run-all2": "^9.0.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "puppeteer": "^25.0.4",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
