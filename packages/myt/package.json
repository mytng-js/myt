{
  "name": "mytng",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "main": "./dist/myt.js",
  "module": "./dist/myt.js",
  "types": "./dist/myt.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "worker": {
        "types": "./dist/myt.d.ts",
        "import": "./dist/myt.js",
        "default": "./dist/myt.js"
      },
      "browser": {
        "types": "./dist/myt.d.ts",
        "import": "./dist/myt-browser.js",
        "default": "./dist/myt-browser.js"
      },
      "node": {
        "types": "./dist/myt.d.ts",
        "import": "./dist/myt.js",
        "default": "./dist/myt.js"
      },
      "types": "./dist/myt.d.ts",
      "import": "./dist/myt.js",
      "default": "./dist/myt.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mytng-js/myt.git"
  },
  "bugs": {
    "url": "https://github.com/mytng-js/myt/issues"
  },
  "homepage": "https://github.com/mytng-js/myt",
  "author": "",
  "license": "MIT"
}
